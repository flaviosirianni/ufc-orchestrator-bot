# Nutrition local prod-like safe profile
BOT_ID=nutrition
INTERACTION_MODE=guided_strict
TELEGRAM_INTERACTION_MODE=guided_strict
BOT_ALLOWED_TELEGRAM_USER_IDS=
BOT_POLICY_PACK=nutrition_guidance_non_clinical
DEFAULT_USER_TIMEZONE=America/Argentina/Buenos_Aires
NUTRITION_SMART_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.2,gpt-4.1-mini
DB_PATH=$HOME/.ufc-orchestrator-bot/nutrition/bot.local.db
NUTRITION_DB_BACKUP_ENABLED=true
NUTRITION_DB_BACKUP_DIR=$HOME/.ufc-orchestrator-bot/nutrition/backups
NUTRITION_DB_BACKUP_INTERVAL_MS=21600000
NUTRITION_DB_BACKUP_RETENTION_DAYS=14
NUTRITION_TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
BILLING_BASE_URL=http://127.0.0.1:3200
BILLING_API_TOKEN=
BILLING_FREE_WEEKLY=5
APP_PUBLIC_URL=http://127.0.0.1:3000
PORT=3000
